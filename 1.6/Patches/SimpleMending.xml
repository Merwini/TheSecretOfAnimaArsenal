<?xml version="1.0" encoding="utf-8"?>
<Patch>

	<Operation Class="PatchOperationFindMod">
		<mods>
			<li>Simple Mending</li>
		</mods>
		<match Class="PatchOperationSequence">
			<operations>
				<li Class="PatchOperationAddModExtension">
					<xpath>Defs/ThingDef[defName="TSOA_AnimaShamanArmor"]</xpath>
					<value>
						<li Class="ComfyCuddlesWithEuterpe.RepairCostExtension">
							<thingDef>TSOA_AnimaGrassResource</thingDef>
							<count>5</count>
							<dynamicScaledCount>20</dynamicScaledCount>
						</li>
					</value>
				</li>
				<li Class="PatchOperationAddModExtension">
					<xpath>Defs/ThingDef[defName="TSOA_AnimaShamanHeaddress"]</xpath>
					<value>
						<li Class="ComfyCuddlesWithEuterpe.RepairCostExtension">
							<thingDef>TSOA_AnimaGrassResource</thingDef>
							<count>5</count>
							<dynamicScaledCount>20</dynamicScaledCount>
						</li>
					</value>
				</li>
			</operations>
		</match>
	</Operation>
	
</Patch>