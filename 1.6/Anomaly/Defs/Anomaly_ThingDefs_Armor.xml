			<li>ApparelArmor</li>
		</thingCategories>

		<apparel>
			<bodyPartGroups>
				<li>Torso</li>
				<li>Shoulders</li>
				<li>Arms</li>
				<li>Legs</li>
			</bodyPartGroups>
			<wornGraphicPath>TSOA/Things/Apparel/VoidInitiate/VoidInitiate</wornGraphicPath>
			<layers>
				<li>Middle</li>
				<li>Shell</li>
			</layers>
			<tags>
				<li>TSOA_VoidArmor</li>
				<li>TSOA_VoidArmorElite</li>
			</tags>
			<defaultOutfitTags>
				<li>Soldier</li>
			</defaultOutfitTags>
		</apparel>

		<tradeability>Sellable</tradeability>
		<tradeTags>
			<li>Clothing</li>
			<li>Armor</li>
		</tradeTags>
	</ThingDef>

	<RecipeDef ParentName="TSOA_ImplantVirionBase">
		<defName>TSOA_ImplantVirionArmor</defName>
		<label>implant virion (bioferrite armor)</label>
		<description>Implant a bioferrite virion in the target. This will gestate into a suit of bioferrite armor, killing the host in the process.</description>
		<descriptionHyperlinks>
			<ThingDef>TSOA_BioferriteVirionArmor</ThingDef>
		</descriptionHyperlinks>
		<surgerySuccessChanceFactor>5</surgerySuccessChanceFactor>
		<uiIconThing>Shard</uiIconThing>

		<researchPrerequisites>
			<li>TSOA_BioferriteImplants</li>
			<li>TSOA_VoidArmor</li>
		</researchPrerequisites>
		<ingredients Inherit="false">
			<li>
				<filter>
					<thingDefs>
						<li>Bioferrite</li>
					</thingDefs>
				</filter>
				<count>120</count>
			</li>
			<li>
				<filter>
					<thingDefs>
						<li>Shard</li>
					</thingDefs>
				</filter>
				<count>1</count>
			</li>
		</ingredients>
		<fixedIngredientFilter Inherit="false">
			<thingDefs>
				<li>Bioferrite</li>
				<li>Shard</li>
			</thingDefs>
		</fixedIngredientFilter>
	</RecipeDef>

