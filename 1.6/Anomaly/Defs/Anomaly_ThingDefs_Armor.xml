			<!-- TODO placeholder -->
			<texPath>TSOA/Things/Apparel/VoidInitiate/VoidInitiate</texPath>
			<graphicClass>Graphic_Single</graphicClass>
			<drawSize>(1.6, 1.6)</drawSize>
		</graphicData>
		<techLevel>Medieval</techLevel>
		<relicChance>2</relicChance>

		<statBases>
			<WorkToMake>38000</WorkToMake>
			<MaxHitPoints>320</MaxHitPoints>
			<Mass>15</Mass>
			<ArmorRating_Sharp>0.6</ArmorRating_Sharp>
			<ArmorRating_Blunt>0.5</ArmorRating_Blunt>
			<ArmorRating_Heat>0.8</ArmorRating_Heat>
			<EquipDelay>15</EquipDelay>
			<TSOA_PsyScaling>0.8</TSOA_PsyScaling>
		</statBases>

		<equippedStatOffsets>
			<MoveSpeed>-0.15</MoveSpeed>
			<MentalBreakThreshold>0.03</MentalBreakThreshold>
			<SlaveSuppressionOffset MayRequire="Ludeon.RimWorld.Ideology">-0.3</SlaveSuppressionOffset>
		</equippedStatOffsets>

		<costList>
			<Bioferrite>120</Bioferrite>
			<Shard>1</Shard>
