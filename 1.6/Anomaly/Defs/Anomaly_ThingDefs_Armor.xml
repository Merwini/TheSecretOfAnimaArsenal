<?xml version="1.0" encoding="utf-8"?>
<Defs>

	<ThingDef ParentName="ArmorSmithableBase">
		<defName>TSOA_VoidArmor</defName>
		<label>void knight plate armor</label>
		<description>A suit of plate armor crafted from bioferrite and gold. The bioferrite feeds on the wearer's psychic presence to harden itself, while gold cladding in key areas prevents the suit from injuring the wearer. While not much stronger than steel armor for the average person, when worn by a powerful psychic its defensive properties are formidable.</description>
		<graphicData>
			<texPath>TSOA/Things/Apparel/VoidKnight/VoidKnight</texPath>
			<graphicClass>Graphic_Single</graphicClass>
			<drawSize>(1.6, 1.6)</drawSize>
		</graphicData>
		<techLevel>Medieval</techLevel>
		<relicChance>2</relicChance>

		<statBases>
			<WorkToMake>38000</WorkToMake>
			<MaxHitPoints>320</MaxHitPoints>
			<Mass>15</Mass>
			<ArmorRating_Sharp>0.9</ArmorRating_Sharp>
			<ArmorRating_Blunt>0.7</ArmorRating_Blunt>
			<ArmorRating_Heat>0.6</ArmorRating_Heat>
			<EquipDelay>15</EquipDelay>
			<TSOA_PsyScaling>0.5</TSOA_PsyScaling>
		</statBases>

		<equippedStatOffsets>
			<MoveSpeed>-0.15</MoveSpeed>
			<SlaveSuppressionOffset MayRequire="Ludeon.RimWorld.Ideology">-0.3</SlaveSuppressionOffset>
		</equippedStatOffsets>

		<costList>
			<Bioferrite>150</Bioferrite>
			<Gold>50</Gold>
		</costList>
		<recipeMaker>
			<researchPrerequisite>TSOA_VoidArmor</researchPrerequisite>
			<unfinishedThingDef>UnfinishedMetallicTechArmor</unfinishedThingDef>
			<recipeUsers>
				<li>ElectricSmithy</li>
				<li>FueledSmithy</li>
			</recipeUsers>
			<skillRequirements>
				<Crafting>7</Crafting>
			</skillRequirements>
			<displayPriority>277</displayPriority>
		</recipeMaker>

		<thingCategories>
			<li>ApparelArmor</li>
		</thingCategories>

		<apparel>
			<bodyPartGroups>
				<li>Torso</li>
				<li>Shoulders</li>
				<li>Arms</li>
				<li>Legs</li>
			</bodyPartGroups>
			<wornGraphicPath>TSOA/Things/Apparel/VoidKnight/VoidKnight</wornGraphicPath>
			<layers>
				<li>Middle</li>
				<li>Shell</li>
			</layers>
			<tags>
				<li>MedievalMilitary</li>
			</tags>
			<defaultOutfitTags>
				<li>Soldier</li>
			</defaultOutfitTags>
		</apparel>

		<tradeability>Sellable</tradeability>
		<tradeTags>
			<li>Clothing</li>
			<li>Armor</li>
		</tradeTags>
	</ThingDef>

	<ThingDef ParentName="ArmorHelmetMakeableBase">
		<defName>TSOA_VoidHelm</defName>
		<label>void knight helm</label>
		<description>A helmet crafted from bioferrite and gold. The bioferrite feeds on the wearer's psychic presence to harden itself, while gold cladding in key areas prevents the suit from injuring the wearer. While not much stronger than steel armor for the average person, when worn by a powerful psychic its defensive properties are formidable.</description>
		<graphicData>
			<texPath>TSOA/Things/Apparel/VoidKnight/VoidKnightHelm_south</texPath>
			<graphicClass>Graphic_Single</graphicClass>
			<drawSize>(1.4, 1.4)</drawSize>
		</graphicData>
		<techLevel>Medieval</techLevel>
		<relicChance>2</relicChance>

		<statBases>
			<WorkToMake>3200</WorkToMake>
			<MaxHitPoints>150</MaxHitPoints>
			<Mass>2</Mass>
			<ArmorRating_Sharp>0.7</ArmorRating_Sharp>
			<ArmorRating_Blunt>0.4</ArmorRating_Blunt>
			<ArmorRating_Heat>0.4</ArmorRating_Heat>
			<EquipDelay>1.5</EquipDelay>
			<TSOA_PsyScaling>0.25</TSOA_PsyScaling>
		</statBases>

		<costList>
			<Bioferrite>50</Bioferrite>
			<Gold>20</Gold>
		</costList>
		<recipeMaker>
			<researchPrerequisite>TSOA_VoidArmor</researchPrerequisite>
			<recipeUsers>
				<li>ElectricSmithy</li>
				<li>FueledSmithy</li>
			</recipeUsers>
			<skillRequirements>
				<Crafting>7</Crafting>
			</skillRequirements>
			<displayPriority>278</displayPriority>
		</recipeMaker>

		<apparel>
			<countsAsClothingForNudity>false</countsAsClothingForNudity>
			<bodyPartGroups>
				<li>FullHead</li>
				<li>Neck</li>
			</bodyPartGroups>
			<wornGraphicPath>TSOA/Things/Apparel/VoidKnight/VoidKnightHelm</wornGraphicPath>
			<layers>
				<li>Overhead</li>
			</layers>
			<tags>
				<li>IndustrialMilitaryBasic</li>
			</tags>
			<defaultOutfitTags>
				<li>Soldier</li>
			</defaultOutfitTags>
		</apparel>

		<tradeability>Sellable</tradeability>
		<tradeTags>
			<li>Clothing</li>
			<li>Armor</li>
		</tradeTags>
	</ThingDef>
	
</Defs>