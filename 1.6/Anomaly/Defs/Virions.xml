	<ThingDef ParentName="TSOA_VirionBase">
		<defName>TSOA_VirionArm</defName>
		<label>bioferrite virion (arm)</label>
		<description>A strange device made from dark archotech nanites, that blurs the lines between organic and inorganic. Implanted into a human, it will slowly consume the recipient's body to grow a piece of bioferrite equipment. If the recipient dies before the growth is complete, a hostile entity will emerge. When complete, it can be surgically removed from the host, although this still kills the host in the process. Takes 10 days for gestation to complete.</description>
		<modExtensions>
			<li Class="tsoa.arsenal.VirionExtension">
				<producedItem>TSOA_BioferriteArm</producedItem>
				<initialGestationDays>10</initialGestationDays>
			</li>
		</modExtensions>
	</ThingDef>
	
	<RecipeDef ParentName="TSOA_ImplantVirionBase">
		<defName>TSOA_ImplantVirionArm</defName>
		<label>implant virion (bioferrite arm)</label>
		<description>Implant a bioferrite virion in the target. This will gestate into a bioferrite arm, killing the host in the process.</description>
		<descriptionHyperlinks>
			<ThingDef>TSOA_BioferriteArm</ThingDef>
		</descriptionHyperlinks>
		<surgerySuccessChanceFactor>5</surgerySuccessChanceFactor>
		<uiIconThing>TSOA_VirionArm</uiIconThing>
		<ingredients Inherit="false">
			<li>
				<filter>
					<thingDefs>
						<li>TSOA_VirionArm</li>
					</thingDefs>
				</filter>
				<count>1</count>
			</li>
		</ingredients>
		<fixedIngredientFilter Inherit="false">
			<thingDefs>
				<li>TSOA_VirionArm</li>
			</thingDefs>
		</fixedIngredientFilter>
	</RecipeDef>

