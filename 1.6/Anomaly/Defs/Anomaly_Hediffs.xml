<?xml version="1.0" encoding="utf-8"?>
<Defs>

	<HediffDef>
		<defName>TSOA_VirionHediff</defName>
		<hediffClass>tsoa.arsenal.Hediff_Virion</hediffClass>
		<label>gestating bioferrite virion</label>
		<labelNoun>gestating a bioferrite virion</labelNoun>
		<description>a bioferrite virion is gestating inside this person</description>
		<isBad>false</isBad>
		<tendable>false</tendable>
		<scenarioCanAdd>true</scenarioCanAdd>
		<stages>
			<li>
				<minSeverity>0.0</minSeverity>
				<label>incubating</label>
				<capMods>
					<li>
						<capacity>Moving</capacity>
						<offset>-0.05</offset>
					</li>
				</capMods>
				<statOffsets>
					<PainShockThreshold>-0.02</PainShockThreshold>
				</statOffsets>
			</li>

			<li>
				<minSeverity>0.33</minSeverity>
				<label>integrating</label>
				<capMods>
					<li>
						<capacity>Moving</capacity>
						<offset>-0.10</offset>
					</li>
					<li>
						<capacity>Manipulation</capacity>
						<offset>-0.10</offset>
					</li>
				</capMods>
				<statOffsets>
					<PainShockThreshold>-0.05</PainShockThreshold>
				</statOffsets>
			</li>

			<li>
				<minSeverity>0.66</minSeverity>
				<label>overwriting</label>
				<capMods>
					<li>
						<capacity>Moving</capacity>
						<offset>-0.20</offset>
					</li>
					<li>
						<capacity>Manipulation</capacity>
						<offset>-0.20</offset>
					</li>
					<li>
						<capacity>Consciousness</capacity>
						<offset>-0.15</offset>
					</li>
				</capMods>
				<statOffsets>
					<PainShockThreshold>-0.10</PainShockThreshold>
				</statOffsets>
			</li>
		</stages>
		<tags>
			<li>TSOA_Virion</li>
		</tags>
	</HediffDef>

</Defs>