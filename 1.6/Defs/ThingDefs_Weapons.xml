<Defs>

	<!-- Anima Tomahawk -->
	<ThingDef ParentName="BaseMeleeWeapon_Sharp_Quality">
		<defName>TSOA_AnimaTomahawk</defName>
		<label>anima hatchet</label>
		<description>A hatchet made to channel the psychic energy of its wielder into destructive force. The haft is carved from anima tree bark and wrapped in anima grass, forming a psychic connection between the wielder and the jade blade set in the head. When wielded by a psycaster, disperses built-up neural heat to deal additional damage with every strike.</description>
		<graphicData>
			<texPath>TSOA/Things/Weapons/AnimaTomahawk</texPath>
			<graphicClass>Graphic_Single</graphicClass>
		</graphicData>
		<equippedAngleOffset>0</equippedAngleOffset>
		<uiIconScale>1.2</uiIconScale>
		<techLevel>Medieval</techLevel>
		<relicChance>3</relicChance>

		<statBases>
			<MaxHitPoints>200</MaxHitPoints>
			<WorkToMake>24000</WorkToMake>
			<Mass>1</Mass>
			<TSOA_EntropyDamage>0.1</TSOA_EntropyDamage>
		</statBases>

		<costList>
			<TSOA_AnimaGrassResource>10</TSOA_AnimaGrassResource>
			<TSOA_AnimaBark>1</TSOA_AnimaBark>
			<Jade>10</Jade>
			<Steel>10</Steel>
		</costList>
		<recipeMaker>
			<researchPrerequisite>TSOA_AnimaWeapons</researchPrerequisite>
			<unfinishedThingDef>UnfinishedWeapon</unfinishedThingDef>
			<skillRequirements>
				<Crafting>7</Crafting>
			</skillRequirements>
			<displayPriority>279</displayPriority>
		</recipeMaker>

		<tools>
			<li>
				<label>handle</label>
				<capacities>
					<li>Poke</li>
				</capacities>
				<power>9</power>
				<cooldownTime>2</cooldownTime>
			</li>
			<li>
				<label>edge</label>
				<capacities>
					<li>Cut</li>
				</capacities>
				<power>14</power>
				<cooldownTime>1.6</cooldownTime>
				<extraMeleeDamages>
					<li>
						<def>TSOA_EntropyExtraDamage</def>
						<amount>2</amount>
					</li>
				</extraMeleeDamages>
			</li>
		</tools>
		<tradeTags>
			<li>WeaponMelee</li>
		</tradeTags>
		<weaponTags>
			<li>TSOA_AnimaWeapons</li>
		</weaponTags>
		<weaponClasses>
			<li>Neolithic</li>
			<li>Melee</li>
		</weaponClasses>
	</ThingDef>

