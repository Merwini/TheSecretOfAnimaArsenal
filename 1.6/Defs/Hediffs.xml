<?xml version="1.0" encoding="utf-8"?>
<Defs>

	<HediffDef ParentName="InjuryBase">
		<defName>TSOA_EntropicDischarge_Injury</defName>
		<label>entropic scorch</label>
		<labelNoun>an entropic scorch</labelNoun>
		<description>a scorch caused by discharged psychic entropy</description>
		<comps>
			<li Class="HediffCompProperties_TendDuration">
				<labelTendedWell>treated</labelTendedWell>
				<labelTendedWellInner>treated</labelTendedWellInner>
				<labelSolidTendedWell>treated</labelSolidTendedWell>
			</li>
			<li Class="HediffCompProperties_GetsPermanent">
				<permanentLabel>neural scarring</permanentLabel>
			</li>
		</comps>
		<injuryProps>
			<painPerSeverity>0.015</painPerSeverity>
			<averagePainPerSeverityPermanent>0.0075</averagePainPerSeverityPermanent>
			<canMerge>true</canMerge>
			<destroyedLabel>Entropically destroyed</destroyedLabel>
			<alwaysUseDestroyedLabel>true</alwaysUseDestroyedLabel>
		</injuryProps>
	</HediffDef>

	<HediffDef ParentName="InjuryBase">
		<defName>TSOA_EntropicDischarge_Skin</defName>
		<label>entropic scorch</label>
		<labelNoun>an entropic scorch</labelNoun>
		<description>a scorch caused by discharged psychic entropy</description>
		<comps>
			<li Class="HediffCompProperties_TendDuration">
				<labelTendedWell>bandaged</labelTendedWell>
				<labelTendedWellInner>dressed</labelTendedWellInner>
				<labelSolidTendedWell>treated</labelSolidTendedWell>
			</li>
			<li Class="HediffCompProperties_Infecter">
				<infectionChance>0.1</infectionChance>
			</li>
			<li Class="HediffCompProperties_GetsPermanent">
				<permanentLabel>entropic scarring</permanentLabel>
			</li>
		</comps>
		<injuryProps>
			<painPerSeverity>0.012</painPerSeverity>
			<averagePainPerSeverityPermanent>0.006</averagePainPerSeverityPermanent>
			<canMerge>true</canMerge>
			<destroyedLabel>Entropically destroyed</destroyedLabel>
			<alwaysUseDestroyedLabel>true</alwaysUseDestroyedLabel>
		</injuryProps>
	</HediffDef>

	<HediffDef ParentName="InjuryBase">
		<defName>TSOA_EntropicDischarge_Solid</defName>
		<label>entropic scorch</label>
		<labelNoun>an entropic scorch</labelNoun>
		<description>a scorch caused by discharged psychic entropy</description>
		<comps>
			<li Class="HediffCompProperties_TendDuration">
				<labelTendedWell>treated</labelTendedWell>
				<labelTendedWellInner>treated</labelTendedWellInner>
				<labelSolidTendedWell>treated</labelSolidTendedWell>
			</li>
			<li Class="HediffCompProperties_GetsPermanent">
				<permanentLabel>permanent entropic scarring</permanentLabel>
			</li>
		</comps>
		<injuryProps>
			<painPerSeverity>0.0125</painPerSeverity>
			<averagePainPerSeverityPermanent>0.0065</averagePainPerSeverityPermanent>
			<destroyedLabel>Entropically destroyed</destroyedLabel>
			<alwaysUseDestroyedLabel>true</alwaysUseDestroyedLabel>
		</injuryProps>
	</HediffDef>

	<HediffDef ParentName="ImplantHediffBase" Abstract="True" Name="TSOA_StatExchangerBase">
		<tags>
			<li>TSOA_Crown</li>
		</tags>
	</HediffDef>
	
	<!-- Needs to be here so I don't have to put the DefOf in a separate assembly -->
	<HediffDef>
		<defName>TSOA_VirionHediff</defName>
		<hediffClass>tsoa.arsenal.Hediff_Virion</hediffClass>
		<label>gestating bioferrite virion</label>
		<labelNoun>gestating a bioferrite virion</labelNoun>
		<description>a bioferrite virion is gestating inside this person</description>
		<isBad>false</isBad>
		<tendable>false</tendable>
		<scenarioCanAdd>true</scenarioCanAdd>
		<tags>
			<li>TSOA_Virion</li>
		</tags>
	</HediffDef>

	<HediffDef>
		<defName>TSOA_VirionActivityHediff</defName>
		<hediffClass>tsoa.arsenal.Hediff_VirionActivity</hediffClass>
		<!-- TODO better term than active -->
		<label>virion active</label>
		<labelNoun>virion activity</labelNoun>
		<description>a virion is causing internal damage</description>
		<isBad>true</isBad>
		<tendable>true</tendable>
		<scenarioCanAdd>false</scenarioCanAdd>
	</HediffDef>

</Defs>