<?xml version="1.0" encoding="utf-8"?>
<Defs>

	<!-- Anima Shaman Armor -->
	<ThingDef ParentName="ApparelBase">
		<defName>TSOA_AnimaShamanArmor</defName>
		<label>anima shaman armor</label>
		<description>A full-body suit of shamanic armor. Made from woven anima grass and plates of anima tree bark, it offers little in the way of physical protection, but when worn by a psycaster passively projects a psychic force field that blocks incoming damage at the cost of building up neural heat. Must be crafted by a psycaster.</description>
		<graphicData>
			<texPath>TSOA/Things/Apparel/AnimaShaman/AnimaShaman</texPath>
			<graphicClass>Graphic_Single</graphicClass>
			<drawSize>(1.6, 1.6)</drawSize>
		</graphicData>
		<techLevel>Medieval</techLevel>
		<tickerType>Normal</tickerType>
		<relicChance>3</relicChance>
		<smeltable>false</smeltable>
		
		<statBases>
			<MaxHitPoints>200</MaxHitPoints>
			<WorkToMake>20000</WorkToMake>
			<Mass>4.0</Mass>
			<Flammability>0.6</Flammability>
			<ArmorRating_Sharp>0.7</ArmorRating_Sharp>
			<ArmorRating_Blunt>0.55</ArmorRating_Blunt>
			<ArmorRating_Heat>0.3</ArmorRating_Heat>
			<EquipDelay>11</EquipDelay>
		</statBases>

		<equippedStatOffsets>
			<SlaveSuppressionOffset MayRequire="Ludeon.RimWorld.Ideology">-0.3</SlaveSuppressionOffset>
		</equippedStatOffsets>
		
		<thingCategories>
			<li>ApparelArmor</li>
		</thingCategories>
		
		<apparel>
			<bodyPartGroups>
				<li>Torso</li>
				<li>Shoulders</li>
				<li>Arms</li>
				<li>Legs</li>
			</bodyPartGroups>
			<wornGraphicPath>TSOA/Things/Apparel/AnimaShaman/AnimaShaman</wornGraphicPath>
			<layers>
				<li>Middle</li>
			</layers>
			<tags>
				<li>TSOA_AnimaArmor</li>
				<li>TSOA_AnimaArmorElite</li>
			</tags>
			<canBeDesiredForIdeo>false</canBeDesiredForIdeo>
			<defaultOutfitTags>
				<li>Soldier</li>
			</defaultOutfitTags>
		</apparel>
		
		<tradeability>Sellable</tradeability>
		<tradeTags>
			<li>Clothing</li>
			<li>Armor</li>
		</tradeTags>
		
		<comps>
			<li Class="tsoa.arsenal.CompProperties_PsyShield" />
		</comps>
	</ThingDef>

	<!-- Anima Shaman Armor Recipe -->
	<RecipeDef>
		<defName>TSOA_Make_AnimaShamanArmor</defName>
		<label>make anima shaman gambeson</label>
		<jobString>Making anima shaman gambeson.</jobString>

		<researchPrerequisite>TSOA_AnimaShamanArmor</researchPrerequisite>

		<workAmount>8000</workAmount>
		<workSkill>Crafting</workSkill>
		<skillRequirements>
			<Crafting>7</Crafting>
		</skillRequirements>
		<effectWorking>Tailor</effectWorking>
		<soundWorking>Recipe_Tailor</soundWorking>
		<unfinishedThingDef>UnfinishedArmor</unfinishedThingDef>
		<displayPriority>275</displayPriority>

		<recipeUsers>
			<li>ElectricTailoringBench</li>
			<li>HandTailoringBench</li>
		</recipeUsers>

		<products>
			<TSOA_AnimaShamanArmor>1</TSOA_AnimaShamanArmor>
		</products>

		<ingredients>
			<li>
				<filter>
					<thingDefs>
						<li>TSOA_AnimaGrassResource</li>
					</thingDefs>
				</filter>
				<count>150</count>
			</li>
			<li>
				<filter>
					<thingDefs>
						<li>TSOA_AnimaBark</li>
					</thingDefs>
				</filter>
				<count>6</count>
			</li>
		</ingredients>

		<modExtensions>
			<li Class="tsoa.core.PsyLinkRecipeExtension">
				<minPsylinkLevel>2</minPsylinkLevel>
			</li>
		</modExtensions>
	</RecipeDef>

	<!-- Anima Shaman Headdress -->
	<ThingDef ParentName="ApparelBase">
		<defName>TSOA_AnimaShamanHeaddress</defName>
		<label>anima shaman headdress</label>
		<description>A ritual headdress woven from anima grass and reinforced with plates of anima tree bark. Provides only light physical protection, but helps the wearer store more neural heat and disperse it more quickly. Must be crafted by a psycaster.</description>
		<graphicData>
			<texPath>TSOA/Things/Apparel/AnimaShaman/AnimaShamanHelm_south</texPath>
			<graphicClass>Graphic_Single</graphicClass>
			<drawSize>(1.2, 1.2)</drawSize>
		</graphicData>
		<techLevel>Medieval</techLevel>
		<relicChance>3</relicChance>
		<smeltable>false</smeltable>

		<statBases>
			<MaxHitPoints>200</MaxHitPoints>
			<WorkToMake>8000</WorkToMake>
			<Mass>1.2</Mass>
			<Flammability>0.6</Flammability>
			<ArmorRating_Sharp>0.40</ArmorRating_Sharp>
			<ArmorRating_Blunt>0.4</ArmorRating_Blunt>
			<ArmorRating_Heat>0.16</ArmorRating_Heat>
		</statBases>
		
		<equippedStatOffsets>
			<PsychicEntropyMaxOffset>20</PsychicEntropyMaxOffset>
			<PsychicEntropyRecoveryRate>0.05</PsychicEntropyRecoveryRate>
			<SlaveSuppressionOffset MayRequire="Ludeon.RimWorld.Ideology">-0.2</SlaveSuppressionOffset>
		</equippedStatOffsets>
		
		<thingCategories>
			<li>ApparelArmor</li>
		</thingCategories>
		
		<apparel>
			<bodyPartGroups>
				<li>UpperHead</li>
				<li>Neck</li>
			</bodyPartGroups>
			<wornGraphicPath>TSOA/Things/Apparel/AnimaShaman/AnimaShamanHelm</wornGraphicPath>
			<layers>
				<li>Overhead</li>
			</layers>
			<tags>
				<li>TSOA_AnimaArmor</li>
				<li>TSOA_AnimaArmorElite</li>
			</tags>
			<canBeDesiredForIdeo>false</canBeDesiredForIdeo>
			<defaultOutfitTags>
				<li>Soldier</li>
			</defaultOutfitTags>
		</apparel>
		
		<tradeability>Sellable</tradeability>
		<tradeTags>
			<li>Clothing</li>
			<li>Armor</li>
		</tradeTags>
	</ThingDef>

