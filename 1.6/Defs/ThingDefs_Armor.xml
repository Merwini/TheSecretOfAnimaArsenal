	<!-- Anima Acolyte Armor -->
	<ThingDef ParentName="ApparelBase">
		<defName>TSOA_AnimaAcolyteArmor</defName>
		<label>anima acolyte gambeson</label>
		<description>A fabric gambeson with an outer layer of anima grass. The gambeson provides minimal protection against attacks when worn by most individuals. When worn by a psycaster, though, the anima grass passively emits a psychic shield that blocks incoming damage, building up neural heat in the wearer. Must be crafted by a psycaster.</description>
		<graphicData>
			<texPath>TSOA/Things/Apparel/AnimaAcolyte/AnArmorStuffable</texPath>
			<graphicClass>Graphic_Single</graphicClass>
			<drawSize>(1, 1)</drawSize>
			<shaderType>CutoutComplex</shaderType>
		</graphicData>
		<techLevel>Medieval</techLevel>
		<tickerType>Normal</tickerType>
		<relicChance>2</relicChance>
		<smeltable>false</smeltable>

		<statBases>
			<MaxHitPoints>200</MaxHitPoints>
			<WorkToMake>20000</WorkToMake>
			<Mass>4.0</Mass>
			<Flammability>0.6</Flammability>
			<StuffEffectMultiplierArmor>0.4</StuffEffectMultiplierArmor>
			<ArmorRating_Sharp>0.3</ArmorRating_Sharp>
			<ArmorRating_Blunt>0.3</ArmorRating_Blunt>
			<StuffEffectMultiplierInsulation_Cold>1</StuffEffectMultiplierInsulation_Cold>
			<StuffEffectMultiplierInsulation_Heat>1</StuffEffectMultiplierInsulation_Heat>
			<EquipDelay>11</EquipDelay>
		</statBases>

		<equippedStatOffsets>
			<SlaveSuppressionOffset MayRequire="Ludeon.RimWorld.Ideology">-0.3</SlaveSuppressionOffset>
		</equippedStatOffsets>

		<thingCategories>
			<li>ApparelArmor</li>
		</thingCategories>

		<stuffCategories>
			<li>Leathery</li>
			<li>Fabric</li>
		</stuffCategories>

		<apparel>
			<bodyPartGroups>
				<li>Torso</li>
				<li>Shoulders</li>
				<li>Arms</li>
				<li>Legs</li>
			</bodyPartGroups>
			<wornGraphicPath>TSOA/Things/Apparel/AnimaAcolyte/AnArmorStuffable</wornGraphicPath>
			<useWornGraphicMask>true</useWornGraphicMask>
			<layers>
				<li>Middle</li>
			</layers>
			<tags>
				<li>TSOA_AnimaArmor</li>
				<li>TSOA_AnimaArmorBasic</li>
			</tags>
			<canBeDesiredForIdeo>false</canBeDesiredForIdeo>
			<defaultOutfitTags>
				<li>Soldier</li>
			</defaultOutfitTags>
		</apparel>

		<tradeability>Sellable</tradeability>
		<tradeTags>
			<li>Clothing</li>
			<li>Armor</li>
		</tradeTags>

		<comps>
			<li Class="tsoa.arsenal.CompProperties_PsyShield">
				<heatPerDamage>0.75</heatPerDamage>
				<resetDelayTicks>180</resetDelayTicks>
			</li>
		</comps>
	</ThingDef>

