<?xml version="1.0" encoding="utf-8"?>
<Defs>
	<StatDef>
		<defName>TSOA_PsyScaling</defName>
		<label>psychic scaling</label>
		<description>Shows how this equipment scales with the wearer's psychic sensitivity.</description>
		<defaultBaseValue>0</defaultBaseValue>
		<category>CapacityEffects</category>
		<displayPriorityInCategory>5</displayPriorityInCategory>
		<toStringStyle>PercentZero</toStringStyle>
		<workerClass>tsoa.arsenal.StatWorker_PsyScalingDisplay</workerClass>
	</StatDef>

	<StatDef>
		<defName>TSOA_EntropyDamage</defName>
		<label>entropy damage</label>
		<description>Shows what percentage of the wielder's current neural heat is consumed to deal extra damage.</description>
		<defaultBaseValue>0</defaultBaseValue>
		<category>CapacityEffects</category>
		<displayPriorityInCategory>6</displayPriorityInCategory>
		<toStringStyle>PercentZero</toStringStyle>
		<workerClass>tsoa.arsenal.StatWorker_EntropyDamageDisplay</workerClass>
	</StatDef>

	<StatDef>
		<defName>TSOA_ComfortFactor</defName>
		<label>comfort factor</label>
		<description>A multiplier on the comfort level that a person experiences.</description>
		<category>PawnHealth</category>
		<toStringStyle>PercentZero</toStringStyle>
		<defaultBaseValue>1</defaultBaseValue>
		<hideAtValue>1</hideAtValue>
		<minValue>0.0001</minValue>
		<showOnAnimals>false</showOnAnimals>
		<showOnDrones>false</showOnDrones>
	</StatDef>
</Defs>