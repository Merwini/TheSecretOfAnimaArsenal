<?xml version="1.0" encoding="utf-8"?>
<Defs>

	<CombatExtended.AmmoCategoryDef>
		<defName>TSOA_AnimaArrowCategory</defName>
		<label>screamer arrow</label>
		<description>Wrapped with anima grass and infused with psychic energy, releases a miniature psychic scream on impact that reduces humans' moods and makes wild animals turn manhunter.</description>
		<advanced>true</advanced>
	</CombatExtended.AmmoCategoryDef>
	
	<ThingDef Class="CombatExtended.AmmoDef" ParentName="AmmoArrowBase">
		<defName>TSOA_Ammo_Arrow_Anima</defName>
		<label>arrow (screamer)</label>
		<graphicData>
			<texPath>TSOA/Things/Ammo/AnimaArrow</texPath>
			<graphicClass>Graphic_StackCount</graphicClass>
		</graphicData>
		<statBases>
			<Mass>0.018</Mass>
		</statBases>
		<ammoClass>TSOA_AnimaArrowCategory</ammoClass>
		<generateAllowChance>0.05</generateAllowChance>
	</ThingDef>

	<ThingDef ParentName="BaseArrowProjectile">
		<defName>TSOA_Projectile_Arrow_Anima</defName>
		<label>arrow (screamer)</label>
		<graphicData>
			<texPath>Things/Projectile/Arrows/Arrow_Stone</texPath>
			<graphicClass>Graphic_Single</graphicClass>
		</graphicData>
		<projectile Class="CombatExtended.ProjectilePropertiesCE">
			<speed>31</speed>
			<damageAmountBase>6</damageAmountBase>
			<armorPenetrationSharp>0.2</armorPenetrationSharp>
			<armorPenetrationBlunt>1.42</armorPenetrationBlunt>
			<preExplosionSpawnChance>0.333</preExplosionSpawnChance>
			<preExplosionSpawnThingDef>TSOA_Ammo_Arrow_Anima</preExplosionSpawnThingDef>
		</projectile>
		<comps>
			<li Class="CombatExtended.CompProperties_ExplosiveCE">
				<damageAmountBase>1</damageAmountBase>
				<explosiveDamageType>TSOA_AnimaScreamer</explosiveDamageType>
				<explosiveRadius>3</explosiveRadius>
				<explosionSound>TSOA_AnimaScreamer</explosionSound>
				<applyDamageToExplosionCellsNeighbors>true</applyDamageToExplosionCellsNeighbors>
			</li>
		</comps>
		<modExtensions>
			<li Class="ProjectileImpactFX.EffectProjectileExtension">
				<AutoAssign>false</AutoAssign>
				<CreateTerrainEffects>true</CreateTerrainEffects>
				<StuckProjectileFleckDef>Fleck_CELandedArrow_Stone</StuckProjectileFleckDef>
				<StuckProjectileFleckSize>0.65</StuckProjectileFleckSize>
			</li>
		</modExtensions>
	</ThingDef>

	<RecipeDef ParentName="AmmoRecipeNeolithicBase">
		<defName>MakeTSOA_Ammo_Arrow_Anima</defName>
		<label>make sceamer arrows x10</label>
		<description>Craft 10 sceamer arrows.</description>
		<jobString>Making sceamer arrows.</jobString>
		<workAmount>200</workAmount>
		<researchPrerequisite>TSOA_AnimaOne</researchPrerequisite>
		<ingredients>
			<li>
				<filter>
					<thingDefs>
						<li>WoodLog</li>
					</thingDefs>
				</filter>
				<count>1</count>
			</li>
			<li>
				<filter>
					<thingDefs>
						<li>TSOA_AnimaGrassResource</li>
					</thingDefs>
				</filter>
				<count>1</count>
			</li>
		</ingredients>
		<fixedIngredientFilter>
			<thingDefs>
				<li>WoodLog</li>
				<li>TSOA_AnimaGrassResource</li>
			</thingDefs>
		</fixedIngredientFilter>
		<products>
			<TSOA_Ammo_Arrow_Anima>10</TSOA_Ammo_Arrow_Anima>
		</products>
	</RecipeDef>
	
</Defs>