<?xml version="1.0" encoding="utf-8"?>
<Patch>

	<Operation Class="CombatExtended.PatchOperationMakeGunCECompatible">
		<defName>TSOA_AnimaBow</defName>
		<statBases>
			<SightsEfficiency>0.8</SightsEfficiency>
			<ShotSpread>1</ShotSpread>
			<SwayFactor>2</SwayFactor>
			<Bulk>4.00</Bulk>
			<RangedWeapon_Cooldown>1</RangedWeapon_Cooldown>
		</statBases>
		<costList>
			<WoodLog>25</WoodLog>
			<TSOA_AnimaGrassResource>5</TSOA_AnimaGrassResource>
			<TSOA_AnimaBark>2</TSOA_AnimaBark>
		</costList>
		<Properties>
			<verbClass>CombatExtended.Verb_ShootCE</verbClass>
			<hasStandardCommand>true</hasStandardCommand>
			<defaultProjectile>Projectile_StreamlinedArrow_Stone</defaultProjectile>
			<warmupTime>1.2</warmupTime>
			<range>22</range>
			<soundCast>Bow_Recurve</soundCast>
		</Properties>
		<AmmoUser>
			<ammoSet>AmmoSet_StreamlinedArrow</ammoSet>
			<AmmoGenPerMagOverride>5</AmmoGenPerMagOverride>
		</AmmoUser>
		<FireModes />
		<weaponTags>
			<li>CE_Bow</li>
		</weaponTags>
		<AllowWithRunAndGun>false</AllowWithRunAndGun>
	</Operation>
	
	<Operation Class="PatchOperationAdd">
		<xpath>Defs/CombatExtended.AmmoSetDef[defName="AmmoSet_Arrow"]/ammoTypes</xpath>
		<value>
			<TSOA_Ammo_Arrow_Anima>TSOA_Projectile_Arrow_Anima</TSOA_Ammo_Arrow_Anima>
		</value>
	</Operation>
	
	<Operation Class="PatchOperationAdd">
		<xpath>Defs/CombatExtended.AmmoSetDef[defName="AmmoSet_StreamlinedArrow"]/ammoTypes</xpath>
		<value>
			<TSOA_Ammo_Arrow_Anima>TSOA_Projectile_Arrow_Anima</TSOA_Ammo_Arrow_Anima>
		</value>
	</Operation>

</Patch>